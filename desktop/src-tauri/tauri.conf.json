{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Thrive",
  "version": "../package.json",
  "identifier": "com.redconvert.thrive",
  "build": {
    "beforeDevCommand": "pnpm tauri:before-dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Thrive",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 28,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.redbox/**",
          "$HOME/.redconvert/**",
          "$HOME/.redconvert.migrated-*/**",
          "$APPDATA/RedBox/**",
          "$HOME/Library/Application Support/RedBox/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis"
    ],
    "resources": [
      "resources/knowledge-api-guide.html",
      "../prompts/library",
      "../builtin-skills"
    ],
    "icon": [
      "../branding/variants/thrive/icons/icon.png",
      "../branding/variants/thrive/icons/icon.icns",
      "../branding/variants/thrive/icons/icon.ico"
    ]
  }
}
